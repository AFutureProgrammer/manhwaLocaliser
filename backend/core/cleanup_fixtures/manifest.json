{
  "schema_version": 1,
  "description": "Small deterministic cleanup planner fixtures. Each case stores the minimal region metadata needed to run build_cleanup_plan without OCR, LLMs, backend servers, or app startup.",
  "default_model_config": {
    "cleanup_backend": "opencv",
    "sam2_enabled": false,
    "cleanup_solid_bubble_fill_enabled": true,
    "cleanup_allow_texture_telea": true,
    "cleanup_allow_translucent_caption": true,
    "cleanup_allow_text_over_art": false,
    "cleanup_allow_sfx_cleanup": false
  },
  "cases": [
    {
      "id": "plain_white_bubble",
      "description": "Plain white dialogue bubble with dark text.",
      "image": "images/plain_white_bubble.png",
      "region": {
        "bbox": [40, 40, 180, 100],
        "text": "테스트",
        "role": "dialog",
        "kind": "PLAIN_BUBBLE",
        "detector": "fixture",
        "confidence": 0.9,
        "text_mask_rects": [[82, 76, 96, 28]]
      },
      "expected": {
        "strategies": ["flat_fill"],
        "methods": ["local_sample"],
        "mask_region_ratio": [0.12, 0.20],
        "mask_container_ratio": [0.12, 0.20],
        "production_allowed": true
      }
    },
    {
      "id": "off_white_bubble",
      "description": "Yellowed/off-white scan bubble; cleanup may use deterministic inpaint instead of forcing pure white.",
      "image": "images/off_white_bubble.png",
      "region": {
        "bbox": [40, 40, 180, 100],
        "text": "테스트",
        "role": "dialog",
        "kind": "PLAIN_BUBBLE",
        "detector": "fixture",
        "confidence": 0.9,
        "text_mask_rects": [[82, 76, 96, 28]]
      },
      "expected": {
        "strategies": ["flat_fill", "mask_inpaint"],
        "methods": ["local_sample", "telea"],
        "mask_region_ratio": [0.12, 0.20],
        "mask_container_ratio": [0.12, 0.20],
        "production_allowed": true
      }
    },
    {
      "id": "colored_bubble",
      "description": "Colored dialogue bubble should sample local color instead of painting white.",
      "image": "images/colored_bubble.png",
      "region": {
        "bbox": [40, 40, 180, 100],
        "text": "테스트",
        "role": "dialog",
        "kind": "PLAIN_BUBBLE",
        "detector": "fixture",
        "confidence": 0.9,
        "text_mask_rects": [[82, 76, 96, 28]]
      },
      "expected": {
        "strategies": ["flat_fill"],
        "methods": ["local_sample"],
        "mask_region_ratio": [0.12, 0.20],
        "mask_container_ratio": [0.18, 0.30],
        "production_allowed": true
      }
    },
    {
